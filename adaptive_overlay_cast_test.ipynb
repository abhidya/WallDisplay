    "    }\n",
    "   },\n",
    "   \"source\": [\n",
    "    \"class FPSController:\\n\",\n",
    "    \"    def __init__(self, target_fps: float):\\n\",\n",
    "    \"        self.target_fps = float(target_fps)\\n\",\n",
    "    \"        self.integral = 0.0\\n\",\n",
    "    \"        self.prev_error = 0.0\\n\",\n",
    "    \"        self.output_fps = max(self.target_fps * 0.8, 1.0)\\n\",\n",
    "    \"        self.kp = 0.3\\n\",\n",
    "    \"        self.ki = 0.05\\n\",\n",
    "    \"        self.kd = 0.1\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def reset(self, target_fps: Optional[float] = None):\\n\",\n",
    "    \"        if target_fps is not None:\\n\",\n",
    "    \"            self.target_fps = float(target_fps)\\n\",\n",
    "    \"        self.integral = 0.0\\n\",\n",
    "    \"        self.prev_error = 0.0\\n\",\n",
    "    \"        self.output_fps = max(self.target_fps * 0.8, 1.0)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def update(self, ffmpeg_fps: Optional[float], stdin_avg_ms: float, dt: float) -> float:\\n\",\n",
    "    \"        dt = max(dt, 0.05)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        if ffmpeg_fps is not None:\\n\",\n",
    "    \"            error = self.target_fps - ffmpeg_fps\\n\",\n",
    "    \"            self.integral += error * dt\\n\",\n",
    "    \"            self.integral = max(-self.target_fps * 10.0, min(self.integral, self.target_fps * 10.0))\\n\",\n",
    "    \"            derivative = (error - self.prev_error) / dt\\n\",\n",
    "    \"\\n\",\n",
    "    \"            adjustment = (\\n\",\n",
    "    \"                self.kp * error\\n\",\n",
    "    \"                + self.ki * self.integral\\n\",\n",
    "    \"                + self.kd * derivative\\n\",\n",
    "    \"            )\\n\",\n",
    "    \"            self.output_fps += adjustment\\n\",\n",
    "    \"            self.prev_error = error\\n\",\n",
    "    \"\\n\",\n",
    "    \"        if stdin_avg_ms > 2.0:\\n\",\n",
    "    \"            ratio = min(1.0, (stdin_avg_ms - 2.0) / 8.0)\\n\",\n",
    "    \"            self.output_fps *= (1.0 - 0.3 * ratio)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        floor = self.target_fps * 0.7\\n\",\n",
    "    \"        self.output_fps = max(floor, min(self.output_fps, self.target_fps))\\n\",\n",
    "    \"        return self.output_fps\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"class AdaptiveController:\\n\",\n",
    "    \"    def __init__(self, initial_profile: str = \\\"medium\\\"):\\n\",\n",
    "    \"        self.profile_idx = [p.name for p in PROFILES].index(initial_profile)\\n\",\n",
    "    \"        self.last_eval_at = 0.0\\n\",\n",
    "    \"        self.last_adjusted_at = 0.0\\n\",\n",
    "    \"        self.overload_streak = 0\\n\",\n",
    "    \"        self.recovery_streak = 0\\n\",\n",
    "    \"\\n\",\n",
    "    \"    @property\\n\",\n",
    "    \"    def profile(self) -> StreamProfile:\\n\",\n",
    "    \"        return PROFILES[self.profile_idx]\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def evaluate(self, metrics: Metrics) -> Optional[str]:\\n\",\n",
    "    \"        now = time.monotonic()\\n\",\n",
    "    \"        if now - self.last_eval_at < EVAL_INTERVAL_S:\\n\",\n",
    "    \"            return None\\n\",\n",
    "    \"        self.last_eval_at = now\\n\",\n",
    "    \"\\n\",\n",
    "    \"        target_fps = float(self.profile.fps)\\n\",\n",
    "    \"        speed = metrics.ffmpeg_speed\\n\",\n",
    "    \"        ffmpeg_fps = metrics.ffmpeg_fps\\n\",\n",
    "    \"        stdin_ms = metrics.avg_stdin_block_ms()\\n\",\n",
    "    \"        source_fps = metrics.source_fps()\\n\",\n",
    "    \"        submit_fps = metrics.submit_fps()\\n\",\n",
    "    \"\\n\",\n",
    "    \"        if speed is None or ffmpeg_fps is None:\\n\",\n",
    "    \"            return None\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # Bottleneck classification from benchmark learnings:\\n\",\n",
    "    \"        # if source/submit cannot sustain target, avoid profile churn.\\n\",\n",
    "    \"        ingest_limited = (\\n\",\n",
    "    \"            source_fps < target_fps * INGEST_GUARD_RATIO\\n\",\n",
    "    \"            or submit_fps < target_fps * INGEST_GUARD_RATIO\\n\",\n",
    "    \"        )\\n\",\n",
    "    \"\\n\",\n",
    "    \"        encoder_limited = (\\n\",\n",
    "    \"            ffmpeg_fps < target_fps * FPS_DOWN_RATIO\\n\",\n",
    "    \"            and submit_fps >= target_fps * SUBMIT_MATCH_RATIO\\n\",\n",
    "    \"        )\\n\",\n",
    "    \"\\n\",\n",
    "    \"        should_down = (\\n\",\n",
    "    \"            encoder_limited\\n\",\n",
    "    \"            or speed < SPEED_DOWN\\n\",\n",
    "    \"            or stdin_ms > 5.0\\n\",\n",
    "    \"        ) and not ingest_limited\\n\",\n",
    "    \"\\n\",\n",
    "    \"        should_up = (\\n\",\n",
    "    \"            speed > SPEED_UP\\n\",\n",
    "    \"            and ffmpeg_fps >= target_fps * FPS_UP_RATIO\\n\",\n",
    "    \"            and stdin_ms < 2.0\\n\",\n",
    "    \"            and source_fps >= target_fps * INGEST_GUARD_RATIO\\n\",\n",
    "    \"            and submit_fps >= target_fps * INGEST_GUARD_RATIO\\n\",\n",
    "    \"        )\\n\",\n",
    "    \"\\n\",\n",
    "    \"        if should_down:\\n\",\n",
