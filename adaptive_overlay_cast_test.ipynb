    "    \"\\n\",\n",
    "    \"    def _resolve_serve_ip(self) -> str:\\n\",\n",
    "    \"        if not self.cast_target:\\n\",\n",
    "    \"            return local_ip()\\n\",\n",
    "    \"\\n\",\n",
    "    \"        target_host = self.cast_target.get(\\\"hostname\\\")\\n\",\n",
    "    \"        action_url = self.cast_target.get(\\\"action_url\\\", \\\"\\\")\\n\",\n",
