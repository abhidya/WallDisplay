    "   \"source\": [\n",
    "    \"class ReusableThreadingHTTPServer(ThreadingHTTPServer):\\n\",\n",
    "    \"    allow_reuse_address = True\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"class OverlayRelayHandler(BaseHTTPRequestHandler):\\n\",\n",
    "    \"    server_version = \\\"AdaptiveOverlayRelay/1.0\\\"\\n\",\n",
    "    \"    protocol_version = \\\"HTTP/1.1\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def log_message(self, fmt: str, *args):\\n\",\n",
    "    \"        return\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def do_GET(self):\\n\",\n",
    "    \"        if self.path != \\\"/live.ts\\\":\\n\",\n",
    "    \"            self.send_error(404)\\n\",\n",
    "    \"            return\\n\",\n",
    "    \"\\n\",\n",
    "    \"        poc = self.server.poc\\n\",\n",
    "    \"        ffmpeg_proc = getattr(self.server, \\\"ffmpeg_proc\\\", None)\\n\",\n",
    "    \"        if poc is None or ffmpeg_proc is None or ffmpeg_proc.stdout is None:\\n\",\n",
    "    \"            self.send_error(503, \\\"Relay not ready\\\")\\n\",\n",
    "    \"            return\\n\",\n",
    "    \"\\n\",\n",
    "    \"        with poc.relay_clients_lock:\\n\",\n",
    "    \"            poc.metrics.relay_clients += 1\\n\",\n",
    "    \"            poc.metrics.relay_peak_clients = max(poc.metrics.relay_peak_clients, poc.metrics.relay_clients)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        self.send_response(200)\\n\",\n",
    "    \"        self.send_header(\\\"Content-Type\\\", \\\"video/mp2t\\\")\\n\",\n",
    "    \"        self.send_header(\\\"Connection\\\", \\\"keep-alive\\\")\\n\",\n",
    "    \"        self.send_header(\\\"Cache-Control\\\", \\\"no-cache, no-store, must-revalidate\\\")\\n\",\n",
    "    \"        self.send_header(\\\"Pragma\\\", \\\"no-cache\\\")\\n\",\n",
    "    \"        self.end_headers()\\n\",\n",
    "    \"\\n\",\n",
    "    \"        try:\\n\",\n",
    "    \"            while not poc.pipeline_stop_event.is_set() and not poc.stop_event.is_set():\\n\",\n",
    "    \"                chunk = ffmpeg_proc.stdout.read(32768)\\n\",\n",
    "    \"                if not chunk:\\n\",\n",
    "    \"                    break\\n\",\n",
    "    \"                self.wfile.write(chunk)\\n\",\n",
    "    \"                poc.metrics.relay_bytes_out += len(chunk)\\n\",\n",
    "    \"        except (BrokenPipeError, ConnectionResetError):\\n\",\n",
    "    \"            pass\\n\",\n",
    "    \"        finally:\\n\",\n",
    "    \"            with poc.relay_clients_lock:\\n\",\n",
    "    \"                poc.metrics.relay_clients = max(0, poc.metrics.relay_clients - 1)\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def build_ffmpeg_cmd(profile: StreamProfile) -> list[str]:\\n\",\n",
    "    \"    encoder = \\\"h264_videotoolbox\\\" if sys.platform == \\\"darwin\\\" else \\\"libx264\\\"\\n\",\n",
    "    \"    encoder_opts = [\\\"-realtime\\\", \\\"1\\\"] if encoder == \\\"h264_videotoolbox\\\" else [\\\"-preset\\\", \\\"ultrafast\\\"]\\n\",\n",
    "    \"    muxrate_k = max(4000, profile.bitrate_k * 3)\\n\",\n",
    "    \"    return [\\n\",\n",
    "    \"        \\\"ffmpeg\\\",\\n\",\n",
    "    \"        \\\"-hide_banner\\\",\\n\",\n",
    "    \"        \\\"-loglevel\\\", \\\"error\\\",\\n\",\n",
    "    \"        \\\"-nostats\\\",\\n\",\n",
    "    \"        \\\"-progress\\\", \\\"pipe:2\\\",\\n\",\n",
    "    \"        \\\"-f\\\", \\\"image2pipe\\\",\\n\",\n",
    "    \"        \\\"-vcodec\\\", \\\"mjpeg\\\",\\n\",\n",
    "    \"        \\\"-i\\\", \\\"-\\\",\\n\",\n",
    "    \"        \\\"-c:v\\\", encoder,\\n\",\n",
    "    \"        *encoder_opts,\\n\",\n",
    "    \"        \\\"-b:v\\\", f\\\"{profile.bitrate_k}k\\\",\\n\",\n",
    "    \"        \\\"-maxrate\\\", f\\\"{profile.bitrate_k}k\\\",\\n\",\n",
    "    \"        \\\"-bufsize\\\", f\\\"{profile.bitrate_k * 2}k\\\",\\n\",\n",
    "    \"        \\\"-g\\\", str(profile.fps),\\n\",\n",
    "    \"        \\\"-keyint_min\\\", str(profile.fps),\\n\",\n",
    "    \"        \\\"-r\\\", str(profile.fps),\\n\",\n",
    "    \"        \\\"-pix_fmt\\\", \\\"yuv420p\\\",\\n\",\n",
    "    \"        \\\"-f\\\", \\\"mpegts\\\",\\n\",\n",
    "    \"        \\\"-muxrate\\\", f\\\"{muxrate_k}k\\\",\\n\",\n",
    "    \"        \\\"-pcr_period\\\", \\\"20\\\",\\n\",\n",
    "    \"        \\\"-mpegts_flags\\\", \\\"+resend_headers\\\",\\n\",\n",
    "    \"        \\\"pipe:1\\\",\\n\",\n",
    "    \"    ]\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def _safe_float(v: str) -> Optional[float]:\\n\",\n",
    "    \"    try:\\n\",\n",
    "    \"        return float(v)\\n\",\n",
    "    \"    except Exception:\\n\",\n",
    "    \"        return None\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def pump_ffmpeg_logs(proc: subprocess.Popen, metrics: Metrics, stop_event: threading.Event):\\n\",\n",
    "    \"    if proc.stderr is None:\\n\",\n",
    "    \"        return\\n\",\n",
    "    \"    for raw in iter(proc.stderr.readline, b\\\"\\\"):\\n\",\n",
    "    \"        if stop_event.is_set():\\n\",\n",
    "    \"            break\\n\",\n",
    "    \"        if not raw:\\n\",\n",
    "    \"            break\\n\",\n",
    "    \"\\n\",\n",
    "    \"        line = raw.decode(\\\"utf-8\\\", errors=\\\"replace\\\").strip()\\n\",\n",
    "    \"        if not line:\\n\",\n",
    "    \"            continue\\n\",\n",
    "    \"\\n\",\n",
    "    \"        key, sep, value = line.partition(\\\"=\\\")\\n\",\n",
    "    \"        if sep:\\n\",\n",
    "    \"            k = key.strip()\\n\",\n",
    "    \"            v = value.strip()\\n\",\n",
    "    \"            if k == \\\"speed\\\":\\n\",\n",
    "    \"                metrics.ffmpeg_speed = _safe_float(v.replace(\\\"x\\\", \\\"\\\"))\\n\",\n",
    "    \"                metrics.last_progress_at = time.monotonic()\\n\",\n",
    "    \"            elif k == \\\"fps\\\":\\n\",\n",
    "    \"                metrics.ffmpeg_fps = _safe_float(v)\\n\",\n",
    "    \"                metrics.last_progress_at = time.monotonic()\\n\",\n",
    "    \"            elif k == \\\"bitrate\\\":\\n\",\n",
    "    \"                m = FFMPEG_BITRATE_RE.search(v)\\n\",\n",
    "    \"                metrics.ffmpeg_bitrate_kbps = _safe_float(m.group(1)) if m else None\\n\",\n",
    "    \"            elif k == \\\"drop_frames\\\":\\n\",\n",
    "    \"                try:\\n\",\n",
    "    \"                    current = int(v)\\n\",\n",
    "    \"                    metrics.drop_frames_delta = max(0, current - metrics.drop_frames)\\n\",\n",
    "    \"                    metrics.drop_frames = current\\n\",\n",
    "    \"                except Exception:\\n\",\n",
    "    \"                    pass\\n\",\n",
    "    \"            elif k == \\\"out_time_ms\\\":\\n\",\n",
    "    \"                metrics.last_progress_at = time.monotonic()\\n\",\n",
    "    \"        else:\\n\",\n",
    "    \"            if \\\"speed=\\\" in line:\\n\",\n",
    "    \"                m = FFMPEG_SPEED_RE.search(line)\\n\",\n",
    "    \"                if m:\\n\",\n",
    "    \"                    metrics.ffmpeg_speed = _safe_float(m.group(1))\\n\",\n",
    "    \"                    metrics.last_progress_at = time.monotonic()\\n\",\n",
    "    \"            if \\\"fps=\\\" in line:\\n\",\n",
    "    \"                m = FFMPEG_FPS_RE.search(line)\\n\",\n",
    "    \"                if m:\\n\",\n",
    "    \"                    metrics.ffmpeg_fps = _safe_float(m.group(1))\\n\",\n",
    "    \"                    metrics.last_progress_at = time.monotonic()\\n\",\n",
    "    \"            if \\\"bitrate=\\\" in line:\\n\",\n",
    "    \"                m = FFMPEG_BITRATE_RE.search(line)\\n\",\n",
    "    \"                if m:\\n\",\n",
    "    \"                    metrics.ffmpeg_bitrate_kbps = _safe_float(m.group(1))\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\"\n",
