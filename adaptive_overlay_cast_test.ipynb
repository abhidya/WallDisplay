    "    \"\\n\",\n",
    "    \"    def _prefix(self) -> str:\\n\",\n",
    "    \"        return f\\\"[{self.name}]\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def _metrics_fresh(self, max_age_s: float = 3.0) -> bool:\\n\",\n",
