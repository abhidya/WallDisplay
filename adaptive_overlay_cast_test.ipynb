    "    \"            '<item id=\\\"0\\\" parentID=\\\"-1\\\" restricted=\\\"1\\\"><dc:title>WallMapper</dc:title>'\\n\",\n",
    "    \"            '<upnp:class>object.item.videoItem</upnp:class>'\\n\",\n",
    "    \"            f'<res protocolInfo=\\\"http-get:*:video/mpeg:DLNA.ORG_PN=MPEG_TS_SD_EU_ISO\\\">{stream_url}</res>'\\n\",\n",
    "    \"            \\\"</item></DIDL-Lite>\\\"\\n\",\n",
    "    \"        )\\n\",\n",
    "    \"        return html.escape(meta)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def _soap_body(self, action: str, stream_url: Optional[str] = None) -> str:\\n\",\n",
    "    \"        if action == \\\"SetAVTransportURI\\\":\\n\",\n",
