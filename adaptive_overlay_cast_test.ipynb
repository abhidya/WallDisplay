    "     \"end_time\": \"2026-03-25T06:15:16.712480Z\",\n",
    "     \"start_time\": \"2026-03-25T06:15:16.601326Z\"\n",
    "    }\n",
    "   },\n",
    "   \"source\": [\n",
    "    \"# Benchmark helpers: strict A/B bottleneck isolation (not production changes).\\n\",\n",
    "    \"import statistics\\n\",\n",
    "    \"import psutil\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"@dataclass\\n\",\n",
    "    \"class BenchmarkResult:\\n\",\n",
    "    \"    case_name: str\\n\",\n",
    "    \"    architecture: str\\n\",\n",
    "    \"    streams: int\\n\",\n",
    "    \"    seconds: float\\n\",\n",
    "    \"    speed_avg: float\\n\",\n",
    "    \"    ffmpeg_fps_avg: float\\n\",\n",
    "    \"    drop_frames_total: int\\n\",\n",
    "    \"    source_fps_avg: float\\n\",\n",
    "    \"    submit_fps_avg: float\\n\",\n",
    "    \"    stdin_avg_ms_avg: float\\n\",\n",
    "    \"    relay_clients_peak_total: int\\n\",\n",
    "    \"    bitrate_kbps_avg: float\\n\",\n",
    "    \"    ffmpeg_cpu_pct_avg: float\\n\",\n",
    "    \"    browser_cpu_pct_avg: float\\n\",\n",
    "    \"    gpu_info: str\\n\",\n",
    "    \"    notes: str = \\\"\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def _safe_avg(values: list[float]) -> float:\\n\",\n",
    "    \"    vals = [v for v in values if v is not None]\\n\",\n",
    "    \"    if not vals:\\n\",\n",
    "    \"        return 0.0\\n\",\n",
    "    \"    return float(statistics.mean(vals))\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def get_benchmark_encoder() -> tuple[str, list[str]]:\\n\",\n",
    "    \"    forced = os.getenv(\\\"POC_BENCH_ENCODER\\\")\\n\",\n",
    "    \"    if forced:\\n\",\n",
    "    \"        if forced == \\\"libx264\\\":\\n\",\n",
    "    \"            return forced, [\\\"-preset\\\", \\\"ultrafast\\\"]\\n\",\n",
    "    \"        return forced, []\\n\",\n",
    "    \"    # Default bench encoder for stability and reproducibility.\\n\",\n",
    "    \"    return \\\"libx264\\\", [\\\"-preset\\\", \\\"ultrafast\\\"]\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def build_ffmpeg_cmd_original(profile: StreamProfile) -> list[str]:\\n\",\n",
    "    \"    encoder = \\\"h264_videotoolbox\\\" if sys.platform == \\\"darwin\\\" else \\\"libx264\\\"\\n\",\n",
    "    \"    encoder_opts = [\\\"-realtime\\\", \\\"1\\\"] if encoder == \\\"h264_videotoolbox\\\" else [\\\"-preset\\\", \\\"ultrafast\\\"]\\n\",\n",
    "    \"    return [\\n\",\n",
    "    \"        \\\"ffmpeg\\\",\\n\",\n",
    "    \"        \\\"-hide_banner\\\",\\n\",\n",
    "    \"        \\\"-loglevel\\\", \\\"error\\\",\\n\",\n",
    "    \"        \\\"-nostats\\\",\\n\",\n",
    "    \"        \\\"-progress\\\", \\\"pipe:2\\\",\\n\",\n",
    "    \"        \\\"-y\\\",\\n\",\n",
    "    \"        \\\"-f\\\", \\\"image2pipe\\\",\\n\",\n",
    "    \"        \\\"-vcodec\\\", \\\"mjpeg\\\",\\n\",\n",
    "    \"        \\\"-i\\\", \\\"-\\\",\\n\",\n",
    "    \"        \\\"-c:v\\\", encoder,\\n\",\n",
    "    \"        *encoder_opts,\\n\",\n",
    "    \"        \\\"-b:v\\\", \\\"2500k\\\",\\n\",\n",
    "    \"        \\\"-r\\\", str(profile.fps),\\n\",\n",
    "    \"        \\\"-pix_fmt\\\", \\\"yuv420p\\\",\\n\",\n",
    "    \"        \\\"-f\\\", \\\"mpegts\\\",\\n\",\n",
    "    \"        \\\"-muxrate\\\", \\\"4000k\\\",\\n\",\n",
    "    \"        \\\"-pcr_period\\\", \\\"20\\\",\\n\",\n",
    "    \"        \\\"pipe:1\\\",\\n\",\n",
    "    \"    ]\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"class OriginalPathOverlayPOC(AdaptiveOverlayPOC):\\n\",\n",
    "    \"    \\\"\\\"\\\"Service-like baseline: fixed cadence, no PID pacing, no duplicate suppression.\\\"\\\"\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def __init__(self, *args, **kwargs):\\n\",\n",
    "    \"        super().__init__(*args, **kwargs)\\n\",\n",
    "    \"        self.enable_profile_scaling = False\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def _stdin_writer(self):\\n\",\n",
    "    \"        assert self.proc is not None and self.proc.stdin is not None\\n\",\n",
    "    \"        target_interval = 1.0 / max(float(self.controller.profile.fps), 1.0)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        while not self.pipeline_stop_event.is_set() and not self.stop_event.is_set():\\n\",\n",
    "    \"            frame, _frame_id = self.slot.snapshot()\\n\",\n",
    "    \"            if frame is not None:\\n\",\n",
    "    \"                try:\\n\",\n",
    "    \"                    w0 = time.perf_counter()\\n\",\n",
    "    \"                    self.proc.stdin.write(frame)\\n\",\n",
    "    \"                    self.proc.stdin.flush()\\n\",\n",
    "    \"                    write_ms = (time.perf_counter() - w0) * 1000.0\\n\",\n",
    "    \"                    self.metrics.stdin_block_time_ms += write_ms\\n\",\n",
    "    \"                    self.metrics.stdin_block_samples.append(write_ms)\\n\",\n",
    "    \"                    self.metrics.submit_frame_count += 1\\n\",\n",
    "    \"                    self.metrics.submit_times.append(time.monotonic())\\n\",\n",
    "    \"                except Exception as exc:\\n\",\n",
    "    \"                    self.capture_error = f\\\"stdin_write_failed: {exc}\\\"\\n\",\n",
    "    \"                    break\\n\",\n",
    "    \"            time.sleep(target_interval)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    async def _playwright_capture(self, overlay_url: str, profile: StreamProfile):\\n\",\n",
    "    \"        from playwright.async_api import async_playwright\\n\",\n",
    "    \"\\n\",\n",
    "    \"        try:\\n\",\n",
    "    \"            async with async_playwright() as p:\\n\",\n",
    "    \"                browser = await p.chromium.launch(headless=True, args=[\\\"--no-sandbox\\\"])\\n\",\n",
    "    \"                page = await browser.new_page(viewport={\\\"width\\\": profile.width, \\\"height\\\": profile.height})\\n\",\n",
    "    \"                await page.goto(overlay_url, wait_until=\\\"domcontentloaded\\\", timeout=15000)\\n\",\n",
    "    \"\\n\",\n",
    "    \"                cdp = await page.context.new_cdp_session(page)\\n\",\n",
    "    \"                next_id = 0\\n\",\n",
    "    \"\\n\",\n",
    "    \"                async def on_frame(ev):\\n\",\n",
    "    \"                    nonlocal next_id\\n\",\n",
    "    \"                    if self.pipeline_stop_event.is_set() or self.stop_event.is_set():\\n\",\n",
    "    \"                        return\\n\",\n",
    "    \"                    jpeg = base64.b64decode(ev[\\\"data\\\"])\\n\",\n",
    "    \"                    self.slot.update(jpeg, next_id)\\n\",\n",
    "    \"                    self.metrics.source_frame_count += 1\\n\",\n",
    "    \"                    self.metrics.source_times.append(time.monotonic())\\n\",\n",
    "    \"                    next_id += 1\\n\",\n",
    "    \"                    await cdp.send(\\\"Page.screencastFrameAck\\\", {\\\"sessionId\\\": ev[\\\"sessionId\\\"]})\\n\",\n",
    "    \"\\n\",\n",
    "    \"                cdp.on(\\\"Page.screencastFrame\\\", lambda ev: asyncio.create_task(on_frame(ev)))\\n\",\n",
    "    \"                await cdp.send(\\n\",\n",
    "    \"                    \\\"Page.startScreencast\\\",\\n\",\n",
    "    \"                    {\\n\",\n",
    "    \"                        \\\"format\\\": \\\"jpeg\\\",\\n\",\n",
    "    \"                        \\\"quality\\\": profile.jpeg_quality,\\n\",\n",
    "    \"                        \\\"maxWidth\\\": profile.width,\\n\",\n",
    "    \"                        \\\"maxHeight\\\": profile.height,\\n\",\n",
    "    \"                        \\\"everyNthFrame\\\": 1,\\n\",\n",
    "    \"                    },\\n\",\n",
    "    \"                )\\n\",\n",
    "    \"\\n\",\n",
    "    \"                try:\\n\",\n",
    "    \"                    while not self.pipeline_stop_event.is_set() and not self.stop_event.is_set():\\n\",\n",
    "    \"                        await asyncio.sleep(0.25)\\n\",\n",
    "    \"                finally:\\n\",\n",
    "    \"                    with suppress(Exception):\\n\",\n",
    "    \"                        await cdp.send(\\\"Page.stopScreencast\\\")\\n\",\n",
    "    \"                    await page.close()\\n\",\n",
    "    \"                    await browser.close()\\n\",\n",
    "    \"        except Exception as exc:\\n\",\n",
    "    \"            self.capture_error = f\\\"{type(exc).__name__}: {exc}\\\"\\n\",\n",
    "    \"            raise\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def _start_pipeline(self, profile: StreamProfile, overlay_url: str):\\n\",\n",
    "    \"        self.pipeline_stop_event.clear()\\n\",\n",
    "    \"        self.slot = LatestFrameSlot()\\n\",\n",
    "    \"        self.capture_error = None\\n\",\n",
    "    \"        self._reset_runtime_health()\\n\",\n",
    "    \"\\n\",\n",
    "    \"        self._start_relay()\\n\",\n",
    "    \"\\n\",\n",
    "    \"        self.proc = subprocess.Popen(\\n\",\n",
    "    \"            build_ffmpeg_cmd_original(profile),\\n\",\n",
    "    \"            stdin=subprocess.PIPE,\\n\",\n",
    "    \"            stdout=subprocess.PIPE,\\n\",\n",
    "    \"            stderr=subprocess.PIPE,\\n\",\n",
    "    \"            bufsize=0,\\n\",\n",
    "    \"        )\\n\",\n",
    "    \"\\n\",\n",
    "    \"        if self.relay_server is not None:\\n\",\n",
    "    \"            self.relay_server.ffmpeg_proc = self.proc\\n\",\n",
    "    \"\\n\",\n",
    "    \"        self.stderr_thread = threading.Thread(\\n\",\n",
    "    \"            target=pump_ffmpeg_logs,\\n\",\n",
    "    \"            args=(self.proc, self.metrics, self.pipeline_stop_event),\\n\",\n",
    "    \"            daemon=True,\\n\",\n",
    "    \"        )\\n\",\n",
    "    \"        self.stdin_thread = threading.Thread(target=self._stdin_writer, daemon=True)\\n\",\n",
    "    \"        self.stderr_thread.start()\\n\",\n",
    "    \"        self.stdin_thread.start()\\n\",\n",
    "    \"\\n\",\n",
    "    \"        self.capture_task = asyncio.create_task(self._playwright_capture(overlay_url, profile))\\n\",\n",
    "    \"        self.running_profile_name = profile.name\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"async def relay_sink_client(url: str, seconds: float, name: str) -> dict:\\n\",\n",
    "    \"    \\\"\\\"\\\"Consume relay output like a DLNA client, to keep ffmpeg stdout drained.\\\"\\\"\\\"\\n\",\n",
    "    \"    start = time.monotonic()\\n\",\n",
    "    \"    deadline = start + seconds\\n\",\n",
    "    \"    bytes_in = 0\\n\",\n",
    "    \"    reconnects = 0\\n\",\n",
    "    \"    errors = []\\n\",\n",
    "    \"    timeout = aiohttp.ClientTimeout(total=None, connect=3)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    async with aiohttp.ClientSession(timeout=timeout) as sess:\\n\",\n",
    "    \"        while time.monotonic() < deadline:\\n\",\n",
    "    \"            reconnects += 1\\n\",\n",
    "    \"            try:\\n\",\n",
    "    \"                async with sess.get(url) as resp:\\n\",\n",
    "    \"                    if resp.status != 200:\\n\",\n",
    "    \"                        errors.append(f\\\"http_{resp.status}\\\")\\n\",\n",
    "    \"                        await asyncio.sleep(0.5)\\n\",\n",
    "    \"                        continue\\n\",\n",
    "    \"                    while time.monotonic() < deadline:\\n\",\n",
    "    \"                        remaining = deadline - time.monotonic()\\n\",\n",
    "    \"                        if remaining <= 0:\\n\",\n",
    "    \"                            break\\n\",\n",
    "    \"                        try:\\n\",\n",
    "    \"                            chunk = await asyncio.wait_for(resp.content.read(32768), timeout=min(1.0, remaining))\\n\",\n",
    "    \"                        except asyncio.TimeoutError:\\n\",\n",
    "    \"                            continue\\n\",\n",
    "    \"                        if not chunk:\\n\",\n",
    "    \"                            break\\n\",\n",
    "    \"                        bytes_in += len(chunk)\\n\",\n",
    "    \"            except Exception as exc:\\n\",\n",
    "    \"                errors.append(f\\\"{type(exc).__name__}:{exc}\\\")\\n\",\n",
    "    \"                await asyncio.sleep(0.5)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    return {\\n\",\n",
    "    \"        \\\"bytes_in\\\": bytes_in,\\n\",\n",
    "    \"        \\\"reconnects\\\": reconnects,\\n\",\n",
    "    \"        \\\"errors\\\": errors,\\n\",\n",
    "    \"    }\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"async def sample_cpu_usage(runners: list[AdaptiveOverlayPOC], seconds: float) -> tuple[float, float]:\\n\",\n",
    "    \"    ffmpeg_samples = []\\n\",\n",
    "    \"    browser_samples = []\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Prime psutil CPU counters.\\n\",\n",
    "    \"    for proc in psutil.process_iter([\\\"pid\\\", \\\"name\\\"]):\\n\",\n",
    "    \"        with suppress(Exception):\\n\",\n",
    "    \"            psutil.Process(proc.info[\\\"pid\\\"]).cpu_percent(interval=None)\\n\",\n",
    "    \"    await asyncio.sleep(0.2)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    start = time.monotonic()\\n\",\n",
    "    \"    while time.monotonic() - start < seconds:\\n\",\n",
    "    \"        ffmpeg_cpu = 0.0\\n\",\n",
    "    \"        for r in runners:\\n\",\n",
    "    \"            if r.proc is not None and r.proc.poll() is None:\\n\",\n",
    "    \"                with suppress(Exception):\\n\",\n",
    "    \"                    ffmpeg_cpu += psutil.Process(r.proc.pid).cpu_percent(interval=None)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        browser_cpu = 0.0\\n\",\n",
    "    \"        for proc in psutil.process_iter([\\\"name\\\"]):\\n\",\n",
    "    \"            name = (proc.info.get(\\\"name\\\") or \\\"\\\").lower()\\n\",\n",
    "    \"            if \\\"chrom\\\" in name or \\\"playwright\\\" in name:\\n\",\n",
    "    \"                with suppress(Exception):\\n\",\n",
    "    \"                    browser_cpu += psutil.Process(proc.pid).cpu_percent(interval=None)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        ffmpeg_samples.append(ffmpeg_cpu)\\n\",\n",
    "    \"        browser_samples.append(browser_cpu)\\n\",\n",
    "    \"        await asyncio.sleep(1.0)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    return _safe_avg(ffmpeg_samples), _safe_avg(browser_samples)\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"async def run_benchmark_case(\\n\",\n",
    "    \"    case_name: str,\\n\",\n",
    "    \"    architecture: str,\\n\",\n",
    "    \"    streams: int,\\n\",\n",
    "    \"    seconds: float = 90,\\n\",\n",
    "    \"    initial_profile: str = \\\"low\\\",\\n\",\n",
    "    \") -> BenchmarkResult:\\n\",\n",
    "    \"    base_port = STREAM_PORT + 100\\n\",\n",
    "    \"    runner_cls = OriginalPathOverlayPOC if architecture == \\\"original\\\" else AdaptiveOverlayPOC\\n\",\n",
    "    \"\\n\",\n",
    "    \"    runners: list[AdaptiveOverlayPOC] = []\\n\",\n",
    "    \"    for i in range(streams):\\n\",\n",
    "    \"        r = runner_cls(\\n\",\n",
    "    \"            initial_profile=initial_profile,\\n\",\n",
    "    \"            stream_port=base_port + i,\\n\",\n",
    "    \"            cast_target=None,\\n\",\n",
    "    \"            name=f\\\"{case_name}-s{i+1}\\\",\\n\",\n",
    "    \"            benchmark_mode=True,\\n\",\n",
    "    \"            fixed_submit_fps=3.0,\\n\",\n",
    "    \"        )\\n\",\n",
    "    \"        # Keep comparable runs; avoid profile restart artifacts.\\n\",\n",
    "    \"        r.enable_profile_scaling = False\\n\",\n",
    "    \"        runners.append(r)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    run_tasks = [asyncio.create_task(r.run(OVERLAY_URL, seconds=seconds)) for r in runners]\\n\",\n",
    "    \"\\n\",\n",
    "    \"    await asyncio.sleep(1.0)\\n\",\n",
    "    \"    sink_tasks = [asyncio.create_task(relay_sink_client(r.stream_url, seconds=seconds, name=r.name)) for r in runners]\\n\",\n",
    "    \"    cpu_task = asyncio.create_task(sample_cpu_usage(runners, seconds=seconds))\\n\",\n",
    "    \"\\n\",\n",
    "    \"    run_results = await asyncio.gather(*run_tasks, return_exceptions=True)\\n\",\n",
    "    \"    sink_results = await asyncio.gather(*sink_tasks, return_exceptions=True)\\n\",\n",
    "    \"    ffmpeg_cpu_avg, browser_cpu_avg = await cpu_task\\n\",\n",
    "    \"\\n\",\n",
    "    \"    speeds = [r.metrics.ffmpeg_speed or 0.0 for r in runners]\\n\",\n",
    "    \"    ffps = [r.metrics.ffmpeg_fps or 0.0 for r in runners]\\n\",\n",
    "    \"    drops = [r.metrics.drop_frames for r in runners]\\n\",\n",
    "    \"    sfps = [r.metrics.source_fps() for r in runners]\\n\",\n",
    "    \"    subfps = [r.metrics.submit_fps() for r in runners]\\n\",\n",
    "    \"    stdinms = [r.metrics.avg_stdin_block_ms() for r in runners]\\n\",\n",
    "    \"    relclients = [r.metrics.relay_peak_clients for r in runners]\\n\",\n",
    "    \"    bitrates = [r.metrics.ffmpeg_bitrate_kbps or 0.0 for r in runners]\\n\",\n",
    "    \"\\n\",\n",
    "    \"    notes = []\\n\",\n",
    "    \"    for rr in run_results:\\n\",\n",
    "    \"        if isinstance(rr, Exception):\\n\",\n",
    "    \"            notes.append(f\\\"run_err:{type(rr).__name__}:{rr}\\\")\\n\",\n",
    "    \"    for sr in sink_results:\\n\",\n",
    "    \"        if isinstance(sr, Exception):\\n\",\n",
    "    \"            notes.append(f\\\"sink_err:{type(sr).__name__}:{sr}\\\")\\n\",\n",
    "    \"        else:\\n\",\n",
    "    \"            if sr.get(\\\"errors\\\"):\\n\",\n",
    "    \"                notes.append(f\\\"sink_errors={len(sr['errors'])}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"    return BenchmarkResult(\\n\",\n",
    "    \"        case_name=case_name,\\n\",\n",
    "    \"        architecture=architecture,\\n\",\n",
    "    \"        streams=streams,\\n\",\n",
    "    \"        seconds=seconds,\\n\",\n",
    "    \"        speed_avg=_safe_avg(speeds),\\n\",\n",
    "    \"        ffmpeg_fps_avg=_safe_avg(ffps),\\n\",\n",
    "    \"        drop_frames_total=int(sum(drops)),\\n\",\n",
    "    \"        source_fps_avg=_safe_avg(sfps),\\n\",\n",
    "    \"        submit_fps_avg=_safe_avg(subfps),\\n\",\n",
    "    \"        stdin_avg_ms_avg=_safe_avg(stdinms),\\n\",\n",
    "    \"        relay_clients_peak_total=int(sum(relclients)),\\n\",\n",
    "    \"        bitrate_kbps_avg=_safe_avg(bitrates),\\n\",\n",
    "    \"        ffmpeg_cpu_pct_avg=ffmpeg_cpu_avg,\\n\",\n",
    "    \"        browser_cpu_pct_avg=browser_cpu_avg,\\n\",\n",
    "    \"        gpu_info=\\\"not_collected_in_notebook\\\",\\n\",\n",
    "    \"        notes=\\\"; \\\".join(notes),\\n\",\n",
    "    \"    )\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"async def synthetic_jpeg_to_ffmpeg_test(seconds: float = 60, fps: int = 8, width: int = 854, height: int = 480) -> dict:\\n\",\n",
    "    \"    \\\"\\\"\\\"Test 5: synthetic JPEG frames to ffmpeg stdin (no Playwright).\\\"\\\"\\\"\\n\",\n",
    "    \"    from PIL import Image, ImageDraw\\n\",\n",
    "    \"    from io import BytesIO\\n\",\n",
    "    \"\\n\",\n",
    "    \"    enc, enc_opts = get_benchmark_encoder()\\n\",\n",
    "    \"    proc = subprocess.Popen(\\n\",\n",
    "    \"        [\\n\",\n",
    "    \"            \\\"ffmpeg\\\", \\\"-hide_banner\\\", \\\"-loglevel\\\", \\\"error\\\", \\\"-nostats\\\", \\\"-progress\\\", \\\"pipe:2\\\",\\n\",\n",
    "    \"            \\\"-f\\\", \\\"image2pipe\\\", \\\"-vcodec\\\", \\\"mjpeg\\\", \\\"-i\\\", \\\"-\\\",\\n\",\n",
    "    \"            \\\"-c:v\\\", enc, *enc_opts,\\n\",\n",
    "    \"            \\\"-b:v\\\", \\\"2500k\\\", \\\"-r\\\", str(fps), \\\"-pix_fmt\\\", \\\"yuv420p\\\",\\n\",\n",
    "    \"            \\\"-f\\\", \\\"mpegts\\\", \\\"-muxrate\\\", \\\"4000k\\\", \\\"-pcr_period\\\", \\\"20\\\", \\\"-\\\",\\n\",\n",
    "    \"        ],\\n\",\n",
    "    \"        stdin=subprocess.PIPE,\\n\",\n",
    "    \"        stdout=subprocess.DEVNULL,\\n\",\n",
    "    \"        stderr=subprocess.PIPE,\\n\",\n",
    "    \"        bufsize=0,\\n\",\n",
    "    \"    )\\n\",\n",
    "    \"\\n\",\n",
    "    \"    m = Metrics()\\n\",\n",
    "    \"    stop = threading.Event()\\n\",\n",
    "    \"    t = threading.Thread(target=pump_ffmpeg_logs, args=(proc, m, stop), daemon=True)\\n\",\n",
    "    \"    t.start()\\n\",\n",
    "    \"\\n\",\n",
    "    \"    img = Image.new(\\\"RGB\\\", (width, height), (18, 18, 18))\\n\",\n",
    "    \"    draw = ImageDraw.Draw(img)\\n\",\n",
    "    \"    draw.text((20, 20), \\\"synthetic\\\", fill=(240, 240, 240))\\n\",\n",
    "    \"    b = BytesIO()\\n\",\n",
    "    \"    img.save(b, format=\\\"JPEG\\\", quality=80)\\n\",\n",
    "    \"    frame = b.getvalue()\\n\",\n",
    "    \"\\n\",\n",
    "    \"    interval = 1.0 / max(1, fps)\\n\",\n",
    "    \"    start = time.monotonic()\\n\",\n",
    "    \"    sent = 0\\n\",\n",
    "    \"    broken_pipe = False\\n\",\n",
    "    \"    while time.monotonic() - start < seconds:\\n\",\n",
    "    \"        try:\\n\",\n",
    "    \"            w0 = time.perf_counter()\\n\",\n",
    "    \"            proc.stdin.write(frame)\\n\",\n",
    "    \"            proc.stdin.flush()\\n\",\n",
    "    \"            m.stdin_block_samples.append((time.perf_counter() - w0) * 1000.0)\\n\",\n",
    "    \"            sent += 1\\n\",\n",
    "    \"        except BrokenPipeError:\\n\",\n",
    "    \"            broken_pipe = True\\n\",\n",
    "    \"            break\\n\",\n",
    "    \"        time.sleep(interval)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    with suppress(Exception):\\n\",\n",
    "    \"        proc.stdin.close()\\n\",\n",
    "    \"    with suppress(Exception):\\n\",\n",
    "    \"        proc.kill()\\n\",\n",
    "    \"    stop.set()\\n\",\n",
    "    \"\\n\",\n",
    "    \"    return {\\n\",\n",
    "    \"        \\\"sent_frames\\\": sent,\\n\",\n",
    "    \"        \\\"speed\\\": m.ffmpeg_speed,\\n\",\n",
    "    \"        \\\"ffmpeg_fps\\\": m.ffmpeg_fps,\\n\",\n",
    "    \"        \\\"drop_frames\\\": m.drop_frames,\\n\",\n",
    "    \"        \\\"stdin_avg_ms\\\": m.avg_stdin_block_ms(),\\n\",\n",
    "    \"        \\\"broken_pipe\\\": broken_pipe,\\n\",\n",
    "    \"        \\\"encoder\\\": enc,\\n\",\n",
    "    \"    }\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def ffmpeg_source_only_test(seconds: float = 60, fps: int = 8, width: int = 854, height: int = 480) -> dict:\\n\",\n",
    "    \"    \\\"\\\"\\\"Test 6: ffmpeg-only encode path from generated source (minimal Python pacing).\\\"\\\"\\\"\\n\",\n",
    "    \"    enc, enc_opts = get_benchmark_encoder()\\n\",\n",
    "    \"    cmd = [\\n\",\n",
    "    \"        \\\"ffmpeg\\\",\\n\",\n",
    "    \"        \\\"-hide_banner\\\", \\\"-loglevel\\\", \\\"error\\\", \\\"-nostats\\\", \\\"-progress\\\", \\\"pipe:2\\\",\\n\",\n",
    "    \"        \\\"-f\\\", \\\"lavfi\\\", \\\"-i\\\", f\\\"testsrc=size={width}x{height}:rate={fps}\\\",\\n\",\n",
    "    \"        \\\"-t\\\", str(seconds),\\n\",\n",
    "    \"        \\\"-c:v\\\", enc, *enc_opts,\\n\",\n",
    "    \"        \\\"-b:v\\\", \\\"2500k\\\", \\\"-r\\\", str(fps), \\\"-pix_fmt\\\", \\\"yuv420p\\\",\\n\",\n",
    "    \"        \\\"-f\\\", \\\"mpegts\\\", \\\"-muxrate\\\", \\\"4000k\\\", \\\"-pcr_period\\\", \\\"20\\\", \\\"-\\\",\\n\",\n",
    "    \"    ]\\n\",\n",
    "    \"    proc = subprocess.Popen(cmd, stdout=subprocess.DEVNULL, stderr=subprocess.PIPE)\\n\",\n",
    "    \"    m = Metrics()\\n\",\n",
    "    \"    stop = threading.Event()\\n\",\n",
    "    \"    t = threading.Thread(target=pump_ffmpeg_logs, args=(proc, m, stop), daemon=True)\\n\",\n",
    "    \"    t.start()\\n\",\n",
    "    \"    proc.wait(timeout=seconds + 20)\\n\",\n",
    "    \"    stop.set()\\n\",\n",
    "    \"    return {\\n\",\n",
    "    \"        \\\"speed\\\": m.ffmpeg_speed,\\n\",\n",
    "    \"        \\\"ffmpeg_fps\\\": m.ffmpeg_fps,\\n\",\n",
    "    \"        \\\"drop_frames\\\": m.drop_frames,\\n\",\n",
    "    \"        \\\"bitrate_kbps\\\": m.ffmpeg_bitrate_kbps,\\n\",\n",
    "    \"        \\\"encoder\\\": enc,\\n\",\n",
    "    \"    }\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def benchmark_table(results: list[BenchmarkResult]):\\n\",\n",
