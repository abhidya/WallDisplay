    "    \"\\n\",\n",
    "    \"        raise ValueError(f\\\"unsupported action: {action}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def _soap_headers(self, action: str, body: bytes) -> dict[str, str]:\\n\",\n",
    "    \"        return {\\n\",\n",
