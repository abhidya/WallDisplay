    "    \"            \\\"Content-Length\\\": str(len(body)),\\n\",\n",
    "    \"            \\\"Connection\\\": \\\"close\\\",\\n\",\n",
    "    \"            \\\"SOAPACTION\\\": f'\\\"urn:schemas-upnp-org:service:AVTransport:1#{action}\\\"',\\n\",\n",
    "    \"        }\\n\",\n",
    "    \"\\n\",\n",
    "    \"    async def _post_soap(self, action_url: str, action: str, body: str, timeout_s: float = 6.0) -> float:\\n\",\n",
    "    \"        payload = body.encode(\\\"utf-8\\\")\\n\",\n",
    "    \"        headers = self._soap_headers(action, payload)\\n\",\n",
    "    \"        timeout = aiohttp.ClientTimeout(total=timeout_s)\\n\",\n",
    "    \"        t0 = time.perf_counter()\\n\",\n",
    "    \"        async with aiohttp.ClientSession(timeout=timeout) as sess:\\n\",\n",
    "    \"            async with sess.post(action_url, data=payload, headers=headers) as r:\\n\",\n",
    "    \"                text = await r.text()\\n\",\n",
    "    \"                if r.status != 200:\\n\",\n",
    "    \"                    raise RuntimeError(f\\\"{action} failed with {r.status}: {text[:300]}\\\")\\n\",\n",
    "    \"        return (time.perf_counter() - t0) * 1000.0\\n\",\n",
    "    \"\\n\",\n",
    "    \"    async def _dlna_start(self):\\n\",\n",
    "    \"        if not self.cast_target:\\n\",\n",
    "    \"            return\\n\",\n",
    "    \"\\n\",\n",
    "    \"        self.cast_metrics.target_name = self.cast_target.get(\\\"friendly_name\\\", \\\"unknown\\\")\\n\",\n",
    "    \"        self.cast_metrics.attempts += 1\\n\",\n",
    "    \"\\n\",\n",
    "    \"        action_url = self.cast_target[\\\"action_url\\\"]\\n\",\n",
    "    \"        serve_ip = self._resolve_serve_ip()\\n\",\n",
    "    \"        self.stream_url = f\\\"http://{serve_ip}:{self.stream_port}/live.ts\\\"\\n\",\n",
    "    \"        self.cast_metrics.stream_url = self.stream_url\\n\",\n",
    "    \"\\n\",\n",
    "    \"        set_uri_body = self._soap_body(\\\"SetAVTransportURI\\\", stream_url=self.stream_url)\\n\",\n",
    "    \"        play_body = self._soap_body(\\\"Play\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"        last_err: Optional[Exception] = None\\n\",\n",
    "    \"        # Ported behavior: SetAVTransportURI then delay then Play.\\n\",\n",
    "    \"        for attempt in range(1, 4):\\n\",\n",
    "    \"            try:\\n\",\n",
    "    \"                self.cast_metrics.set_uri_ms = await self._post_soap(action_url, \\\"SetAVTransportURI\\\", set_uri_body)\\n\",\n",
    "    \"                self.cast_metrics.set_uri_ok = True\\n\",\n",
    "    \"                await asyncio.sleep(3.0)\\n\",\n",
    "    \"                self.cast_metrics.play_ms = await self._post_soap(action_url, \\\"Play\\\", play_body)\\n\",\n",
    "    \"                self.cast_metrics.play_ok = True\\n\",\n",
    "    \"                return\\n\",\n",
    "    \"            except Exception as exc:\\n\",\n",
    "    \"                last_err = exc\\n\",\n",
    "    \"                self.cast_metrics.errors.append(f\\\"start_attempt_{attempt}:{type(exc).__name__}:{exc}\\\")\\n\",\n",
    "    \"                await asyncio.sleep(min(2.0, 0.5 * attempt))\\n\",\n",
    "    \"\\n\",\n",
    "    \"        raise RuntimeError(f\\\"DLNA start failed after retries: {last_err}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"    async def _dlna_stop(self):\\n\",\n",
    "    \"        if not self.cast_target:\\n\",\n",
    "    \"            return\\n\",\n",
    "    \"\\n\",\n",
    "    \"        action_url = self.cast_target[\\\"action_url\\\"]\\n\",\n",
    "    \"        stop_body = self._soap_body(\\\"Stop\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"        try:\\n\",\n",
    "    \"            self.cast_metrics.stop_ms = await self._post_soap(action_url, \\\"Stop\\\", stop_body, timeout_s=4.0)\\n\",\n",
    "    \"            self.cast_metrics.stop_ok = True\\n\",\n",
    "    \"        except Exception as exc:\\n\",\n",
    "    \"            self.cast_metrics.errors.append(f\\\"stop:{type(exc).__name__}:{exc}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def _stdin_writer(self):\\n\",\n",
    "    \"        assert self.proc is not None and self.proc.stdin is not None\\n\",\n",
    "    \"        last_frame_id = -1\\n\",\n",
    "    \"        last_submit = 0.0\\n\",\n",
    "    \"        last_update = time.monotonic()\\n\",\n",
    "    \"\\n\",\n",
    "    \"        while not self.pipeline_stop_event.is_set() and not self.stop_event.is_set():\\n\",\n",
    "    \"            now = time.monotonic()\\n\",\n",
    "    \"            dt = max(0.05, now - last_update)\\n\",\n",
    "    \"            last_update = now\\n\",\n",
    "    \"\\n\",\n",
    "    \"            target_fps = float(self.controller.profile.fps)\\n\",\n",
    "    \"            self.fps_controller.target_fps = target_fps\\n\",\n",
    "    \"            if self.benchmark_mode and self.fixed_submit_fps is not None:\\n\",\n",
    "    \"                effective_fps = float(self.fixed_submit_fps)\\n\",\n",
    "    \"                self.fps_controller.output_fps = effective_fps\\n\",\n",
    "    \"            elif self.benchmark_mode:\\n\",\n",
    "    \"                effective_fps = target_fps\\n\",\n",
    "    \"                self.fps_controller.output_fps = effective_fps\\n\",\n",
    "    \"            else:\\n\",\n",
    "    \"                effective_fps = self.fps_controller.update(\\n\",\n",
    "    \"                    ffmpeg_fps=self.metrics.ffmpeg_fps if self._metrics_fresh() else None,\\n\",\n",
    "    \"                    stdin_avg_ms=self.metrics.avg_stdin_block_ms(),\\n\",\n",
    "    \"                    dt=dt,\\n\",\n",
    "    \"                )\\n\",\n",
    "    \"            target_interval = 1.0 / max(effective_fps, 1.0)\\n\",\n",
    "    \"\\n\",\n",
    "    \"            self.slot.event.wait(timeout=target_interval)\\n\",\n",
    "    \"            if self.pipeline_stop_event.is_set() or self.stop_event.is_set():\\n\",\n",
    "    \"                break\\n\",\n",
    "    \"\\n\",\n",
    "    \"            frame, frame_id = self.slot.snapshot()\\n\",\n",
    "    \"            if frame is None:\\n\",\n",
    "    \"                self.slot.event.clear()\\n\",\n",
    "    \"                continue\\n\",\n",
    "    \"            if frame_id == last_frame_id:\\n\",\n",
    "    \"                self.metrics.duplicate_skip_count += 1\\n\",\n",
    "    \"                self.slot.event.clear()\\n\",\n",
    "    \"                continue\\n\",\n",
    "    \"\\n\",\n",
    "    \"            now_perf = time.perf_counter()\\n\",\n",
    "    \"            dt_submit = now_perf - last_submit\\n\",\n",
    "    \"            if last_submit > 0 and dt_submit < target_interval:\\n\",\n",
    "    \"                time.sleep(target_interval - dt_submit)\\n\",\n",
    "    \"\\n\",\n",
    "    \"            try:\\n\",\n",
    "    \"                w0 = time.perf_counter()\\n\",\n",
    "    \"                self.proc.stdin.write(frame)\\n\",\n",
    "    \"                self.proc.stdin.flush()\\n\",\n",
    "    \"                write_ms = (time.perf_counter() - w0) * 1000.0\\n\",\n",
    "    \"                self.metrics.stdin_block_time_ms += write_ms\\n\",\n",
    "    \"                self.metrics.stdin_block_samples.append(write_ms)\\n\",\n",
    "    \"            except Exception as exc:\\n\",\n",
    "    \"                self.capture_error = f\\\"stdin_write_failed: {exc}\\\"\\n\",\n",
    "    \"                break\\n\",\n",
    "    \"\\n\",\n",
    "    \"            last_submit = time.perf_counter()\\n\",\n",
    "    \"            last_frame_id = frame_id\\n\",\n",
    "    \"            self.metrics.submit_frame_count += 1\\n\",\n",
    "    \"            self.metrics.submit_times.append(time.monotonic())\\n\",\n",
    "    \"\\n\",\n",
    "    \"    async def _playwright_capture(self, overlay_url: str, profile: StreamProfile):\\n\",\n",
    "    \"        from playwright.async_api import async_playwright\\n\",\n",
    "    \"\\n\",\n",
    "    \"        try:\\n\",\n",
    "    \"            async with async_playwright() as p:\\n\",\n",
    "    \"                browser = await p.chromium.launch(\\n\",\n",
    "    \"                    headless=True,\\n\",\n",
    "    \"                    args=[\\n\",\n",
    "    \"                        \\\"--no-sandbox\\\",\\n\",\n",
    "    \"                        \\\"--disable-background-timer-throttling\\\",\\n\",\n",
    "    \"                        \\\"--disable-backgrounding-occluded-windows\\\",\\n\",\n",
    "    \"                        \\\"--disable-renderer-backgrounding\\\",\\n\",\n",
    "    \"                    ],\\n\",\n",
    "    \"                )\\n\",\n",
    "    \"                page = await browser.new_page(viewport={\\\"width\\\": profile.width, \\\"height\\\": profile.height})\\n\",\n",
    "    \"                await page.goto(overlay_url, wait_until=\\\"domcontentloaded\\\", timeout=15000)\\n\",\n",
    "    \"\\n\",\n",
    "    \"                cdp = await page.context.new_cdp_session(page)\\n\",\n",
    "    \"                next_id = 0\\n\",\n",
    "    \"\\n\",\n",
    "    \"                async def on_frame(ev):\\n\",\n",
    "    \"                    nonlocal next_id\\n\",\n",
    "    \"                    if self.pipeline_stop_event.is_set() or self.stop_event.is_set():\\n\",\n",
    "    \"                        return\\n\",\n",
    "    \"                    jpeg = base64.b64decode(ev[\\\"data\\\"])\\n\",\n",
    "    \"                    self.slot.update(jpeg, next_id)\\n\",\n",
    "    \"                    self.metrics.source_frame_count += 1\\n\",\n",
    "    \"                    self.metrics.source_times.append(time.monotonic())\\n\",\n",
    "    \"                    next_id += 1\\n\",\n",
    "    \"                    await cdp.send(\\\"Page.screencastFrameAck\\\", {\\\"sessionId\\\": ev[\\\"sessionId\\\"]})\\n\",\n",
    "    \"\\n\",\n",
    "    \"                cdp.on(\\\"Page.screencastFrame\\\", lambda ev: asyncio.create_task(on_frame(ev)))\\n\",\n",
    "    \"                await cdp.send(\\n\",\n",
    "    \"                    \\\"Page.startScreencast\\\",\\n\",\n",
    "    \"                    {\\n\",\n",
    "    \"                        \\\"format\\\": \\\"jpeg\\\",\\n\",\n",
    "    \"                        \\\"quality\\\": profile.jpeg_quality,\\n\",\n",
    "    \"                        \\\"maxWidth\\\": profile.width,\\n\",\n",
    "    \"                        \\\"maxHeight\\\": profile.height,\\n\",\n",
    "    \"                        \\\"everyNthFrame\\\": 1,\\n\",\n",
    "    \"                    },\\n\",\n",
    "    \"                )\\n\",\n",
    "    \"\\n\",\n",
    "    \"                try:\\n\",\n",
    "    \"                    while not self.pipeline_stop_event.is_set() and not self.stop_event.is_set():\\n\",\n",
    "    \"                        await asyncio.sleep(0.25)\\n\",\n",
    "    \"                finally:\\n\",\n",
    "    \"                    with suppress(Exception):\\n\",\n",
    "    \"                        await cdp.send(\\\"Page.stopScreencast\\\")\\n\",\n",
    "    \"                    await page.close()\\n\",\n",
    "    \"                    await browser.close()\\n\",\n",
    "    \"        except Exception as exc:\\n\",\n",
    "    \"            self.capture_error = f\\\"{type(exc).__name__}: {exc}\\\"\\n\",\n",
    "    \"            raise\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def _reset_runtime_health(self):\\n\",\n",
    "    \"        self.metrics.ffmpeg_speed = None\\n\",\n",
    "    \"        self.metrics.ffmpeg_fps = None\\n\",\n",
    "    \"        self.metrics.ffmpeg_bitrate_kbps = None\\n\",\n",
    "    \"        self.metrics.drop_frames = 0\\n\",\n",
    "    \"        self.metrics.drop_frames_delta = 0\\n\",\n",
    "    \"        self.metrics.last_progress_at = 0.0\\n\",\n",
    "    \"        self.metrics.stdin_block_samples.clear()\\n\",\n",
    "    \"        self.warmup_until = time.monotonic() + 8.0\\n\",\n",
    "    \"        self.zero_fps_since = None\\n\",\n",
    "    \"        self.no_client_since = None\\n\",\n",
    "    \"        self.fps_controller.reset(self.controller.profile.fps)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def _start_pipeline(self, profile: StreamProfile, overlay_url: str):\\n\",\n",
    "    \"        self.pipeline_stop_event.clear()\\n\",\n",
    "    \"        self.slot = LatestFrameSlot()\\n\",\n",
    "    \"        self.capture_error = None\\n\",\n",
    "    \"        self._reset_runtime_health()\\n\",\n",
    "    \"\\n\",\n",
    "    \"        self._start_relay()\\n\",\n",
    "    \"\\n\",\n",
    "    \"        self.proc = subprocess.Popen(\\n\",\n",
    "    \"            build_ffmpeg_cmd(profile),\\n\",\n",
    "    \"            stdin=subprocess.PIPE,\\n\",\n",
    "    \"            stdout=subprocess.PIPE,\\n\",\n",
    "    \"            stderr=subprocess.PIPE,\\n\",\n",
    "    \"            bufsize=0,\\n\",\n",
    "    \"        )\\n\",\n",
    "    \"\\n\",\n",
    "    \"        if self.relay_server is not None:\\n\",\n",
    "    \"            self.relay_server.ffmpeg_proc = self.proc\\n\",\n",
    "    \"\\n\",\n",
    "    \"        self.stderr_thread = threading.Thread(\\n\",\n",
    "    \"            target=pump_ffmpeg_logs,\\n\",\n",
    "    \"            args=(self.proc, self.metrics, self.pipeline_stop_event),\\n\",\n",
    "    \"            daemon=True,\\n\",\n",
    "    \"        )\\n\",\n",
    "    \"        self.stdin_thread = threading.Thread(target=self._stdin_writer, daemon=True)\\n\",\n",
    "    \"        self.stderr_thread.start()\\n\",\n",
    "    \"        self.stdin_thread.start()\\n\",\n",
    "    \"\\n\",\n",
    "    \"        self.capture_task = asyncio.create_task(self._playwright_capture(overlay_url, profile))\\n\",\n",
    "    \"        self.running_profile_name = profile.name\\n\",\n",
    "    \"\\n\",\n",
    "    \"    async def _stop_pipeline(self, stop_relay: bool = False):\\n\",\n",
    "    \"        self.pipeline_stop_event.set()\\n\",\n",
    "    \"        self.slot.event.set()\\n\",\n",
    "    \"\\n\",\n",
    "    \"        if self.capture_task is not None:\\n\",\n",
    "    \"            if not self.capture_task.done():\\n\",\n",
    "    \"                self.capture_task.cancel()\\n\",\n",
    "    \"            with suppress(asyncio.CancelledError, Exception):\\n\",\n",
    "    \"                await self.capture_task\\n\",\n",
    "    \"            self.capture_task = None\\n\",\n",
    "    \"\\n\",\n",
    "    \"        if self.proc is not None:\\n\",\n",
    "    \"            with suppress(Exception):\\n\",\n",
    "    \"                if self.proc.stdin:\\n\",\n",
    "    \"                    self.proc.stdin.close()\\n\",\n",
    "    \"            with suppress(Exception):\\n\",\n",
    "    \"                self.proc.kill()\\n\",\n",
    "    \"            self.proc = None\\n\",\n",
    "    \"\\n\",\n",
    "    \"        if stop_relay:\\n\",\n",
    "    \"            self._stop_relay()\\n\",\n",
    "    \"\\n\",\n",
    "    \"    async def run(self, overlay_url: str, seconds: float = 30.0):\\n\",\n",
    "    \"        print(f\\\"{self._prefix()} POC start: seconds={seconds}, initial_profile={self.controller.profile.name}, stream={self.stream_url}, profile_scaling={self.enable_profile_scaling}, benchmark_mode={self.benchmark_mode}, fixed_submit_fps={self.fixed_submit_fps}\\\")\\n\",\n",
    "    \"        self._start_pipeline(self.controller.profile, overlay_url)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        if self.cast_target:\\n\",\n",
    "    \"            try:\\n\",\n",
    "    \"                # Match service behavior: prime encoder/relay before DLNA handoff.\\n\",\n",
    "    \"                await asyncio.sleep(6.0)\\n\",\n",
    "    \"                await self._dlna_start()\\n\",\n",
    "    \"                print(f\\\"{self._prefix()} cast_start ok -> {self.cast_metrics.short()}\\\")\\n\",\n",
    "    \"            except Exception as exc:\\n\",\n",
    "    \"                self.cast_metrics.errors.append(f\\\"start:{type(exc).__name__}:{exc}\\\")\\n\",\n",
    "    \"                print(f\\\"{self._prefix()} cast_start failed -> {exc}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"        deadline = time.monotonic() + seconds\\n\",\n",
    "    \"        no_frame_deadline = time.monotonic() + 8.0\\n\",\n",
    "    \"\\n\",\n",
    "    \"        try:\\n\",\n",
    "    \"            while time.monotonic() < deadline and not self.stop_event.is_set():\\n\",\n",
    "    \"                if self.capture_task and self.capture_task.done():\\n\",\n",
    "    \"                    exc = self.capture_task.exception()\\n\",\n",
    "    \"                    if exc is not None:\\n\",\n",
    "    \"                        raise RuntimeError(f\\\"Playwright capture failed: {exc}\\\") from exc\\n\",\n",
    "    \"\\n\",\n",
    "    \"                if self.metrics.source_frame_count == 0 and time.monotonic() > no_frame_deadline:\\n\",\n",
    "    \"                    raise RuntimeError(\\\"No source frames captured after 8s. Check OVERLAY_URL and Playwright install.\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"                now = time.monotonic()\\n\",\n",
    "    \"                action = None\\n\",\n",
    "    \"                if self.enable_profile_scaling and now >= self.warmup_until and self._metrics_fresh():\\n\",\n",
    "    \"                    action = self.controller.evaluate(self.metrics)\\n\",\n",
    "    \"\\n\",\n",
    "    \"                ffps = self.metrics.ffmpeg_fps\\n\",\n",
    "    \"                if now >= self.warmup_until and self._metrics_fresh() and ffps is not None and ffps <= 0.05:\\n\",\n",
    "    \"                    if self.zero_fps_since is None:\\n\",\n",
    "    \"                        self.zero_fps_since = now\\n\",\n",
    "    \"                else:\\n\",\n",
    "    \"                    self.zero_fps_since = None\\n\",\n",
    "    \"\\n\",\n",
    "    \"                if action:\\n\",\n",
    "    \"                    print(f\\\"{self._prefix()} [{time.strftime('%H:%M:%S')}] {action}\\\")\\n\",\n",
    "    \"                    if self.running_profile_name != self.controller.profile.name:\\n\",\n",
    "    \"                        with suppress(asyncio.CancelledError, Exception):\\n\",\n",
    "    \"                            await self._stop_pipeline(stop_relay=False)\\n\",\n",
    "    \"                        self._start_pipeline(self.controller.profile, overlay_url)\\n\",\n",
    "    \"\\n\",\n",
    "    \"                if self.zero_fps_since is not None and (now - self.zero_fps_since) > 10.0:\\n\",\n",
    "    \"                    print(f\\\"{self._prefix()} [{time.strftime('%H:%M:%S')}] force_recover -> ffmpeg_fps==0 for >10s\\\")\\n\",\n",
    "    \"                    self.zero_fps_since = None\\n\",\n",
    "    \"                    with suppress(asyncio.CancelledError, Exception):\\n\",\n",
    "    \"                        await self._stop_pipeline(stop_relay=False)\\n\",\n",
    "    \"                    self._start_pipeline(self.controller.profile, overlay_url)\\n\",\n",
    "    \"\\n\",\n",
    "    \"                # Cast-mode fail-fast: if renderer disconnects and does not reconnect, restart cast handshake.\\n\",\n",
    "    \"                if self.cast_target:\\n\",\n",
    "    \"                    if self.metrics.relay_clients <= 0:\\n\",\n",
    "    \"                        if self.no_client_since is None:\\n\",\n",
    "    \"                            self.no_client_since = now\\n\",\n",
    "    \"                    else:\\n\",\n",
    "    \"                        self.no_client_since = None\\n\",\n",
    "    \"\\n\",\n",
    "    \"                    if self.no_client_since is not None and (now - self.no_client_since) > 8.0:\\n\",\n",
    "    \"                        print(f\\\"{self._prefix()} [{time.strftime('%H:%M:%S')}] no_client_recover -> relay client missing >8s\\\")\\n\",\n",
    "    \"                        self.no_client_since = None\\n\",\n",
    "    \"                        with suppress(asyncio.CancelledError, Exception):\\n\",\n",
    "    \"                            await self._stop_pipeline(stop_relay=False)\\n\",\n",
    "    \"                        self._start_pipeline(self.controller.profile, overlay_url)\\n\",\n",
    "    \"                        with suppress(Exception):\\n\",\n",
    "    \"                            await asyncio.sleep(2.0)\\n\",\n",
    "    \"                            await self._dlna_start()\\n\",\n",
    "    \"\\n\",\n",
    "    \"                print(\\n\",\n",
    "    \"                    f\\\"{self._prefix()} profile={self.controller.profile.name:6s} target={self.controller.profile.fps:>2d} \\\"\\n\",\n",
    "    \"                    f\\\"speed={self.metrics.ffmpeg_speed} ffmpeg_fps={self.metrics.ffmpeg_fps} \\\"\\n\",\n",
    "    \"                    f\\\"source_fps={self.metrics.source_fps():.2f} submit_fps={self.metrics.submit_fps():.2f} \\\"\\n\",\n",
    "    \"                    f\\\"drop={self.metrics.drop_frames} ddrop={self.metrics.drop_frames_delta} \\\"\\n\",\n",
    "    \"                    f\\\"stdin_avg_ms={self.metrics.avg_stdin_block_ms():.2f} pid_submit={self.fps_controller.output_fps:.2f} \\\"\\n\",\n",
    "    \"                    f\\\"clients={self.metrics.relay_clients}\\\"\\n\",\n",
    "    \"                )\\n\",\n",
    "    \"                await asyncio.sleep(2.0)\\n\",\n",
    "    \"        finally:\\n\",\n",
    "    \"            self.stop_event.set()\\n\",\n",
    "    \"            await self._dlna_stop()\\n\",\n",
    "    \"            with suppress(asyncio.CancelledError, Exception):\\n\",\n",
    "    \"                await self._stop_pipeline(stop_relay=True)\\n\",\n",
    "    \"\\n\",\n",
    "    \"            print(f\\\"\\\\n{self._prefix()} Final metrics\\\")\\n\",\n",
    "    \"            print(\\\"profile:\\\", self.controller.profile.name)\\n\",\n",
    "    \"            print(\\\"target_fps:\\\", self.controller.profile.fps)\\n\",\n",
    "    \"            print(\\\"stream_url:\\\", self.stream_url)\\n\",\n",
    "    \"            print(\\\"speed:\\\", self.metrics.ffmpeg_speed)\\n\",\n",
    "    \"            print(\\\"ffmpeg_fps:\\\", self.metrics.ffmpeg_fps)\\n\",\n",
    "    \"            print(\\\"bitrate_kbps:\\\", self.metrics.ffmpeg_bitrate_kbps)\\n\",\n",
    "    \"            print(\\\"drop_frames:\\\", self.metrics.drop_frames)\\n\",\n",
    "    \"            print(\\\"source_fps:\\\", round(self.metrics.source_fps(), 3))\\n\",\n",
