    "    \"            return (\\n\",\n",
    "    \"                \\\"<?xml version='1.0' encoding='utf-8'?>\\\"\\n\",\n",
    "    \"                '<s:Envelope s:encodingStyle=\\\"http://schemas.xmlsoap.org/soap/encoding/\\\" '\\n\",\n",
    "    \"                'xmlns:s=\\\"http://schemas.xmlsoap.org/soap/envelope/\\\">'\\n\",\n",
    "    \"                \\\"<s:Body>\\\"\\n\",\n",
    "    \"                '<u:SetAVTransportURI xmlns:u=\\\"urn:schemas-upnp-org:service:AVTransport:1\\\">'\\n\",\n",
    "    \"                \\\"<InstanceID>0</InstanceID>\\\"\\n\",\n",
    "    \"                f\\\"<CurrentURI>{stream_url or self.stream_url}</CurrentURI>\\\"\\n\",\n",
    "    \"                f\\\"<CurrentURIMetaData>{metadata}</CurrentURIMetaData>\\\"\\n\",\n",
    "    \"                \\\"</u:SetAVTransportURI>\\\"\\n\",\n",
    "    \"                \\\"</s:Body></s:Envelope>\\\"\\n\",\n",
    "    \"            )\\n\",\n",
    "    \"\\n\",\n",
    "    \"        if action == \\\"Play\\\":\\n\",\n",
    "    \"            return (\\n\",\n",
    "    \"                \\\"<?xml version='1.0' encoding='utf-8'?>\\\"\\n\",\n",
    "    \"                '<s:Envelope s:encodingStyle=\\\"http://schemas.xmlsoap.org/soap/encoding/\\\" '\\n\",\n",
    "    \"                'xmlns:s=\\\"http://schemas.xmlsoap.org/soap/envelope/\\\">'\\n\",\n",
    "    \"                \\\"<s:Body>\\\"\\n\",\n",
    "    \"                '<u:Play xmlns:u=\\\"urn:schemas-upnp-org:service:AVTransport:1\\\">'\\n\",\n",
    "    \"                \\\"<InstanceID>0</InstanceID><Speed>1</Speed>\\\"\\n\",\n",
    "    \"                \\\"</u:Play>\\\"\\n\",\n",
    "    \"                \\\"</s:Body></s:Envelope>\\\"\\n\",\n",
    "    \"            )\\n\",\n",
    "    \"\\n\",\n",
    "    \"        if action == \\\"Stop\\\":\\n\",\n",
    "    \"            return (\\n\",\n",
    "    \"                \\\"<?xml version='1.0' encoding='utf-8'?>\\\"\\n\",\n",
    "    \"                '<s:Envelope s:encodingStyle=\\\"http://schemas.xmlsoap.org/soap/encoding/\\\" '\\n\",\n",
    "    \"                'xmlns:s=\\\"http://schemas.xmlsoap.org/soap/envelope/\\\">'\\n\",\n",
    "    \"                \\\"<s:Body>\\\"\\n\",\n",
    "    \"                '<u:Stop xmlns:u=\\\"urn:schemas-upnp-org:service:AVTransport:1\\\">'\\n\",\n",
    "    \"                \\\"<InstanceID>0</InstanceID>\\\"\\n\",\n",
    "    \"                \\\"</u:Stop>\\\"\\n\",\n",
