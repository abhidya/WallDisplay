    "   \"source\": [\n",
    "    \"@dataclass(frozen=True)\\n\",\n",
    "    \"class StreamProfile:\\n\",\n",
    "    \"    name: str\\n\",\n",
    "    \"    width: int\\n\",\n",
    "    \"    height: int\\n\",\n",
    "    \"    fps: int\\n\",\n",
    "    \"    jpeg_quality: int\\n\",\n",
    "    \"    bitrate_k: int\\n\",\n",
    "    \"\\n\",\n",
    "    \"PROFILES = [\\n\",\n",
    "    \"    StreamProfile(\\\"tiny\\\", 640, 360, 2, 20, 600),\\n\",\n",
    "    \"    # StreamProfile(\\\"tiny\\\", 640, 360, 6, 20, 600),\\n\",\n",
    "    \"    # StreamProfile(\\\"tiny\\\", 640, 360, 6, 20, 600),\\n\",\n",
    "    \"    # StreamProfile(\\\"tiny\\\", 640, 360, 6, 20, 600),\\n\",\n",
    "    \"    StreamProfile(\\\"low\\\", 854, 480, 8, 24, 900),\\n\",\n",
    "    \"    StreamProfile(\\\"medium\\\", 960, 540, 10, 30, 1500),\\n\",\n",
    "    \"    StreamProfile(\\\"high\\\", 1280, 720, 15, 34, 2200),\\n\",\n",
    "    \"]\\n\",\n",
    "    \"\\n\",\n",
    "    \"PROFILE_BY_NAME = {p.name: p for p in PROFILES}\\n\",\n",
    "    \"\\n\",\n",
    "    \"@dataclass\\n\",\n",
    "    \"class Metrics:\\n\",\n",
    "    \"    ffmpeg_speed: Optional[float] = None\\n\",\n",
    "    \"    ffmpeg_fps: Optional[float] = None\\n\",\n",
    "    \"    ffmpeg_bitrate_kbps: Optional[float] = None\\n\",\n",
    "    \"    drop_frames: int = 0\\n\",\n",
    "    \"    drop_frames_delta: int = 0\\n\",\n",
    "    \"    last_progress_at: float = 0.0\\n\",\n",
    "    \"\\n\",\n",
    "    \"    source_frame_count: int = 0\\n\",\n",
    "    \"    submit_frame_count: int = 0\\n\",\n",
    "    \"    duplicate_skip_count: int = 0\\n\",\n",
    "    \"    proactive_drop_count: int = 0\\n\",\n",
    "    \"    stdin_block_time_ms: float = 0.0\\n\",\n",
    "    \"\\n\",\n",
    "    \"    relay_clients: int = 0\\n\",\n",
    "    \"    relay_peak_clients: int = 0\\n\",\n",
    "    \"    relay_bytes_out: int = 0\\n\",\n",
    "    \"\\n\",\n",
    "    \"    source_times: deque = field(default_factory=lambda: deque(maxlen=240))\\n\",\n",
    "    \"    submit_times: deque = field(default_factory=lambda: deque(maxlen=240))\\n\",\n",
    "    \"    stdin_block_samples: deque = field(default_factory=lambda: deque(maxlen=120))\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def source_fps(self, window: float = 5.0) -> float:\\n\",\n",
    "    \"        now = time.monotonic()\\n\",\n",
    "    \"        return sum(1 for t in self.source_times if now - t <= window) / max(window, 0.001)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def submit_fps(self, window: float = 5.0) -> float:\\n\",\n",
    "    \"        now = time.monotonic()\\n\",\n",
    "    \"        return sum(1 for t in self.submit_times if now - t <= window) / max(window, 0.001)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def avg_stdin_block_ms(self) -> float:\\n\",\n",
    "    \"        if not self.stdin_block_samples:\\n\",\n",
    "    \"            return 0.0\\n\",\n",
    "    \"        return sum(self.stdin_block_samples) / len(self.stdin_block_samples)\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"@dataclass\\n\",\n",
    "    \"class CastMetrics:\\n\",\n",
    "    \"    target_name: str = \\\"\\\"\\n\",\n",
    "    \"    stream_url: str = \\\"\\\"\\n\",\n",
    "    \"    set_uri_ok: bool = False\\n\",\n",
    "    \"    play_ok: bool = False\\n\",\n",
    "    \"    stop_ok: bool = False\\n\",\n",
    "    \"    set_uri_ms: float = 0.0\\n\",\n",
    "    \"    play_ms: float = 0.0\\n\",\n",
    "    \"    stop_ms: float = 0.0\\n\",\n",
    "    \"    attempts: int = 0\\n\",\n",
    "    \"    errors: list[str] = field(default_factory=list)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def short(self) -> str:\\n\",\n",
    "    \"        return (\\n\",\n",
    "    \"            f\\\"target={self.target_name} set={self.set_uri_ok}({self.set_uri_ms:.0f}ms) \\\"\\n\",\n",
    "    \"            f\\\"play={self.play_ok}({self.play_ms:.0f}ms) stop={self.stop_ok}({self.stop_ms:.0f}ms) \\\"\\n\",\n",
    "    \"            f\\\"attempts={self.attempts} errs={len(self.errors)}\\\"\\n\",\n",
    "    \"        )\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"@dataclass\\n\",\n",
    "    \"class LatestFrameSlot:\\n\",\n",
    "    \"    data: Optional[bytes] = None\\n\",\n",
    "    \"    frame_id: int = -1\\n\",\n",
    "    \"    lock: threading.Lock = field(default_factory=threading.Lock)\\n\",\n",
    "    \"    event: threading.Event = field(default_factory=threading.Event)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def update(self, data: bytes, frame_id: int):\\n\",\n",
    "    \"        with self.lock:\\n\",\n",
    "    \"            self.data = data\\n\",\n",
    "    \"            self.frame_id = frame_id\\n\",\n",
    "    \"            self.event.set()\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def snapshot(self):\\n\",\n",
    "    \"        with self.lock:\\n\",\n",
    "    \"            return self.data, self.frame_id\\n\"\n",
    "   ],\n",
