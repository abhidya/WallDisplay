    "   \"source\": [\n",
    "    \"# Adaptive Overlay Cast POC (Notebook-Only)\\n\",\n",
    "    \"\\n\",\n",
    "    \"This notebook is a **POC harness** to validate adaptive control before touching production service code.\\n\",\n",
    "    \"\\n\",\n",
    "    \"Pipeline under test:\\n\",\n",
    "    \"- Playwright capture (browser JPEG frames)\\n\",\n",
    "    \"- event-driven frame submit to FFmpeg (no duplicate re-send)\\n\",\n",
    "    \"- FFmpeg MPEG-TS encode\\n\",\n",
    "    \"- optional relay probe\\n\",\n",
    "    \"\\n\",\n",
    "    \"Control objective:\\n\",\n",
    "    \"- converge to stable throughput\\n\",\n",
    "    \"- avoid overload when `ffmpeg_fps` falls below target\\n\",\n",
    "    \"- use strict rules based on both `ffmpeg_speed` and `ffmpeg_fps`\\n\"\n",
    "   ],\n",
    "   \"id\": \"56c6c4b54a96ce9d\"\n",
    "  },\n",
