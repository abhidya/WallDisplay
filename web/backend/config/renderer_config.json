{
  "server_base_url": "http://localhost:8000",
  "senders": {
    "direct": {
      "enabled": true,
      "default_display": 0,
      "browser_path": "/Applications/Google Chrome.app/Contents/MacOS/Google Chrome",
      "kiosk_mode": true
    },
    "hdmi": {
      "enabled": true,
      "default_display": 1,
      "browser_path": "",
      "kiosk_mode": true,
      "heartbeat_timeout_seconds": 15,
      "isolated_profile": true
    },
    "dlna": {
      "enabled": true,
      "stream_port_range": [9000, 9100],
      "connect_timeout": 5
    },
    "airplay": {
      "enabled": true,
      "script_path": "auto",
      "connect_timeout": 10
    }
  },
  "renderers": {
    "chrome": {
      "path": "/Applications/Google Chrome.app/Contents/MacOS/Google Chrome",
      "args": ["--kiosk", "--disable-infobars", "--no-first-run"],
      "timeout": 30,
      "headless": true
    },
    "chrome-visible": {
      "path": "/Applications/Google Chrome.app/Contents/MacOS/Google Chrome",
      "args": ["--kiosk", "--disable-infobars", "--no-first-run", "--start-fullscreen"],
      "timeout": 30,
      "headless": false
    }
  },
  "scenes": {
    "frontdoor-v1": {
      "template": "overlay_frontdoor/index.html",
      "data": {
        "weather_key": "env:WEATHER_API",
        "muni_stop": 13915,
        "video_host": "http://10.0.0.74",
        "video_ports": [9000, 8999, 8998],
        "video_file": "door6.mp4"
      }
    },
    "overlay-frontdoor": {
      "template": "/Users/abdulrehmanbhidya/PycharmProjects/overlay frontdoor/index.html",
      "data": {
        "autoplay": true,
        "loop": true,
        "video_file": "/Users/abdulrehmanbhidya/PycharmProjects/nano-dlna/door6.mp4",
        "video_host": "http://10.0.0.74",
        "video_ports": [9000, 8999, 8998]
      }
    },
    "kitchen-v1": {
      "template": "kitchendoorv2.mp4",
      "data": {
        "autoplay": true,
        "loop": true
      }
    },
    "blank": {
      "template": "blank.html",
      "data": {
        "background_color": "black"
      }
    }
  },
  "projectors": {
    "proj-hallway": {
      "sender": "airplay",
      "target_name": "Hallway TV",
      "fallback_sender": "dlna",
      "fallback_target": "Hallway_TV_DLNA"
    },
    "proj-kitchen": {
      "sender": "dlna",
      "target_name": "SideProjector_dlna"
    },
    "proj-local": {
      "sender": "direct",
      "target_name": "0"
    },
    "proj-hdmi-local": {
      "name": "HDMI Projector",
      "sender": "hdmi",
      "target_name": "\\\\.\\DISPLAY5",
      "content_mode": "identify",
      "content_modes": ["identify", "structured_light", "overlay", "blank", "scene"],
      "content_options": {
        "pattern_set": "gray_code",
        "frame_duration_ms": 300,
        "safe_black_between_frames": true
      }
    },
    "proj-as": {
      "sender": "airplay",
      "target_name": "AS-Projector[AirPlay]"
    },
    "proj-hccast": {
      "sender": "airplay",
      "target_name": "Hccast-3ADE76",
      "scene": "overlay-frontdoor",
      "renderer": "chrome-visible"
    }
  },
  "automations": {
    "airplay_hccast_overlay": {
      "enabled": true,
      "projector_id": "proj-hccast",
      "target_name_pattern": "hccast",
      "overlay_config_id": 2,
      "overlay_base_url": "http://localhost:8000",
      "controls_hidden": true,
      "display_mode": "extend",
      "cooldown_seconds": 15,
      "display_wait_seconds": 12,
      "launch_stabilization_seconds": 1.5
    }
  },
  "health_check_interval": 10
}
