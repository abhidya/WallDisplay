<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>__SERVICE_LABEL__.git-updater</string>
    <key>ProgramArguments</key>
    <array>
        <string>__ROOT_DIR__/service/git_auto_update.sh</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>StartInterval</key>
    <integer>300</integer>
    <key>WorkingDirectory</key>
    <string>__ROOT_DIR__</string>
    <key>StandardOutPath</key>
    <string>__LOG_DIR__/launchd-git-updater.out.log</string>
    <key>StandardErrorPath</key>
    <string>__LOG_DIR__/launchd-git-updater.err.log</string>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    </dict>
</dict>
</plist>
